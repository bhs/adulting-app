# Database
# For local development, you can use SQLite:
# DATABASE_URL="file:./dev.db"

# For production (Render, Vercel, etc.), use PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# For Render.com deployment:
# DATABASE_URL is automatically set by Render when using render.yaml
# No need to manually configure it

# Node Environment
NODE_ENV="development"

# OpenTelemetry Configuration
# OTLP endpoint for sending telemetry data (traces, metrics, logs)
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# Service name for identifying the application in observability tools
OTEL_SERVICE_NAME="adulting-app"

# Browser-side OTLP endpoint (must be accessible from the client)
# For local development with Docker Compose:
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"

# For production, this should be your public OTel Collector endpoint:
# NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT="https://otel-collector.yourdomain.com"
