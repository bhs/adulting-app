# Database
# For local development, you can use SQLite:
# DATABASE_URL="file:./dev.db"

# For production (Render, Vercel, etc.), use PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# For Render.com deployment:
# DATABASE_URL is automatically set by Render when using render.yaml
# No need to manually configure it

# Node Environment
NODE_ENV="development"

# OpenTelemetry Configuration
# OTLP Exporter Endpoint (required for telemetry export)
# For Grafana Cloud: https://otlp-gateway-prod-<region>.grafana.net/otlp
# For Honeycomb: https://api.honeycomb.io
# For Axiom: https://api.axiom.co
OTEL_EXPORTER_OTLP_ENDPOINT="https://otlp-gateway-prod-us-central-0.grafana.net/otlp"

# OTLP Headers (for authentication)
# For Grafana Cloud format: Authorization=Basic <base64-encoded-instance-id:api-key>
# For Honeycomb format: x-honeycomb-team=<api-key>
# For Axiom format: Authorization=Bearer <api-key>
OTEL_EXPORTER_OTLP_HEADERS="Authorization=Basic <base64-encoded-credentials>"

# Service name for telemetry
OTEL_SERVICE_NAME="adulting-app"

# Service version
OTEL_SERVICE_VERSION="1.0.0"

# Browser-side OpenTelemetry (optional)
# Only set this if you want to enable browser-side tracing
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT=""
NEXT_PUBLIC_OTEL_SERVICE_NAME="adulting-app-browser"
