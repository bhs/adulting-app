# Database
# For local development, use a local SQLite file
DATABASE_URL="file:./dev.db"

# For production (Vercel), you might want to use a hosted database
# DATABASE_URL="postgresql://user:password@host:port/database"
# DATABASE_URL="mysql://user:password@host:port/database"

# For GCP Cloud Run with Cloud SQL
# DATABASE_URL="postgresql://appuser:password@localhost/adulting?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME"

# Node Environment
NODE_ENV="development"

# GCP Configuration (for deployment scripts)
GCP_PROJECT_ID="your-project-id"
GCP_REGION="us-central1"
SERVICE_NAME="adulting-app"
CLOUD_SQL_INSTANCE="adulting-db"
DATABASE_NAME="adulting"
DATABASE_USER="appuser"
