# Database
# For local development, you can use SQLite:
# DATABASE_URL="file:./dev.db"

# For production (Render, Vercel, etc.), use PostgreSQL:
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# For Render.com deployment:
# DATABASE_URL is automatically set by Render when using render.yaml
# No need to manually configure it

# Node Environment
NODE_ENV="development"

# Sentry Error Tracking
# Get your DSN from: https://sentry.io/settings/projects/<your-project>/keys/
# Free tier: 5,000 errors/month, 10,000 performance units/month
SENTRY_DSN="https://your-sentry-dsn@sentry.io/your-project-id"
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/your-project-id"

# Optional: For uploading source maps (recommended for production)
# Get auth token from: https://sentry.io/settings/account/api/auth-tokens/
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="your-project-slug"
SENTRY_AUTH_TOKEN="your-auth-token"

# Plausible Analytics
# For self-hosted: Set NEXT_PUBLIC_PLAUSIBLE_HOST to your instance URL
# For cloud: Use default (https://plausible.io)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="yourdomain.com"
# NEXT_PUBLIC_PLAUSIBLE_HOST="https://plausible.io"  # Optional, defaults to plausible.io
