# Local Development Environment Variables
# Copy this file to .env.local for local development

# Database (SQLite for local development)
DATABASE_URL="file:./dev.db"

# Node Environment
NODE_ENV="development"

# OpenTelemetry Configuration for Local Development with Docker Compose
# Server-side OTLP endpoint (within Docker network)
OTEL_EXPORTER_OTLP_ENDPOINT="http://otel-collector:4318"
OTEL_SERVICE_NAME="adulting-app"

# Browser-side OTLP endpoint (accessible from host machine)
# This must be accessible from your browser
NEXT_PUBLIC_OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
