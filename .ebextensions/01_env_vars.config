# Load environment variables from AWS SSM Parameter Store
# This configuration runs during Elastic Beanstalk deployment

files:
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/01_load_ssm_params.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      set -e

      # Get SSM parameter path from environment
      SSM_PATH="${SSM_PARAMETER_PATH:-/nextjs-app/}"
      AWS_REGION="${AWS_REGION:-us-east-1}"

      echo "Loading parameters from SSM path: $SSM_PATH"

      # Fetch all parameters from the path
      PARAMS=$(aws ssm get-parameters-by-path \
        --path "$SSM_PATH" \
        --with-decryption \
        --region "$AWS_REGION" \
        --query 'Parameters[*].[Name,Value]' \
        --output text)

      # Create environment file
      ENV_FILE="/var/app/current/.env"

      # Write parameters to .env file
      echo "$PARAMS" | while read -r name value; do
        # Extract parameter name (remove path prefix)
        param_name=$(echo "$name" | sed "s|$SSM_PATH||")
        echo "$param_name=$value" >> "$ENV_FILE"
      done

      # Set proper permissions
      chown webapp:webapp "$ENV_FILE"
      chmod 600 "$ENV_FILE"

      echo "Environment variables loaded successfully"

option_settings:
  # Node.js platform configuration
  aws:elasticbeanstalk:container:nodejs:
    ProxyServer: nginx
    GzipCompression: true

  # Enhanced health reporting
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: enhanced

  # CloudWatch Logs
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7
